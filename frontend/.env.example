# Writz frontend — environment configuration
# Copy this file to `.env.local` and adjust as needed.
# NEXT_PUBLIC_* values are sent to the browser; everything else is server-only.

# Soroban RPC + network
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract addresses (Soroban testnet — see contracts/deployments/testnet.md)
NEXT_PUBLIC_COMMITMENT_TREE_ID=CDFAP3J4WLFZC2N5U66X5EO62POBBIBXOKCCMCM3IRLJNXT73C4IBKA7
NEXT_PUBLIC_BITCOIN_SPV_ID=CAE5L7BO2GNF7MIZWXB2BTUMLYNIMQZUSWN2BWLZQS7HRHLOUSL6VLWJ
NEXT_PUBLIC_ZK_VERIFIER_ID=CDV45GLXG4AOU6BDZSY5YHHVNGQIAYAPD3PUGXIIIYLIO6V2XGO6SMFV
NEXT_PUBLIC_PRIVATE_LEND_ID=CCLH2GJYG3QSHZJI7V7VK3DNMNK3I3QJCECBSFGX3AC6CK4I7EF7ZJ2G
NEXT_PUBLIC_USDC_TOKEN_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Off-chain services (set once deployed — see issues #2 and #14)
NEXT_PUBLIC_RELAYER_URL=
NEXT_PUBLIC_PROVER_URL=

# ── Server-side secrets (NOT NEXT_PUBLIC — never exposed to the browser) ──
# Protocol Bitcoin co-signing key used by POST /api/cosign to add the protocol
# signature on a cooperative collateral release. WIF-encoded; testnet only;
# keep out of source control.
PROTOCOL_SIGNING_KEY=
# Bitcoin network for co-signing: "testnet" (default) or "mainnet".
BITCOIN_NETWORK=testnet
