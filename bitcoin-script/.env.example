# Writz Protocol — Bitcoin Script E2E Test
# Copy to .env.local and fill in your values.
# bun run e2e:testnet / bun run e2e:dryrun load .env.local automatically.

# ── Private keys (32-byte hex) ─────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
E2E_PROTOCOL_PRIVKEY=
E2E_USER_PRIVKEY=

# ── Network ────────────────────────────────────────────────────────────────────
E2E_ESPLORA_URL=https://blockstream.info/signet/api
E2E_CLTV_TIMELOCK=700000

# ── Derived keys (fill in after first dry-run) ─────────────────────────────────
E2E_PROTOCOL_PUBKEY=
E2E_USER_PUBKEY=

# ── Derived addresses (fill in after first dry-run) ────────────────────────────
E2E_DEPOSIT_ADDRESS=
E2E_USER_RETURN_ADDRESS=

# ── Live transactions (fill in after broadcast) ────────────────────────────────
E2E_FUNDING_TXID=
E2E_RELEASE_TXID=
