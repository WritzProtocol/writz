{
  "name": "@writz/bitcoin-script",
  "version": "0.1.0",
  "description": "P2WSH locking script construction and transaction signing for Writz Protocol",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format cjs --sourcemap",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "e2e:testnet": "bun run scripts/e2e_testnet.mjs",
    "e2e:dryrun": "bun run scripts/e2e_testnet.mjs --dry-run"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.0.5",
    "bitcoinjs-lib": "^6.1.7",
    "ecpair": "^2.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4"
  }
}
