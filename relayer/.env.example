# Writz Relayer — environment variables
# Copy to .env and fill in values before running.

# TCP port the relayer listens on (default: 3000)
PORT=3000

# Bitcoin network: "mainnet" or "signet" (default: mainnet)
# "testnet" is accepted as a legacy alias for "signet"
BITCOIN_NETWORK=mainnet

# Blockstream Esplora API base URL.
# Defaults to the public Blockstream endpoint for the chosen network.
# ESPLORA_URL=https://blockstream.info/api

# Allowed CORS origin(s) for browser requests.
# Use "*" to allow all origins (default).
# Use a comma-separated list to restrict: "https://app.writz.io,http://localhost:3001"
CORS_ORIGIN=*

# Minimum confirmations returned when the caller doesn't specify (default: 6)
DEFAULT_CONFIRMATIONS=6

# Maximum confirmations a caller may request (default: 20)
MAX_CONFIRMATIONS=20

# HTTP request timeout for Esplora calls in milliseconds (default: 10000)
REQUEST_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Stellar / Soroban
# ---------------------------------------------------------------------------

# Soroban RPC endpoint (defaults to public testnet)
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase (defaults to testnet)
# STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Soroban contract address for the commitment-tree contract
COMMITMENT_TREE_ID=

# Admin Stellar secret key — used to sign insert_commitment transactions.
# Must match the account configured as admin in the deployed contract.
ADMIN_SECRET=
